# Asset-Play Screener — environment configuration (copy to .env)
# All keys are FREE. None of these are committed; .env is gitignored.

# DART OpenAPI (https://opendart.fss.or.kr) — corpCode, financials, 타법인출자현황
ASSET_PLAY_DART_API_KEY=

# V-World (https://vworld.kr) — 주소→PNU geocoder + 개별공시지가(NED 속성정보).
# data.go.kr "국토교통부_개별공시지가정보"는 LINK형 API라 키 발급/호출이 V-World에서 이뤄진다.
# V-World 키 하나로 지오코딩 + 개별공시지가를 모두 호출할 수 있다.
ASSET_PLAY_VWORLD_KEY=

# (선택) 공공데이터포털 직접 엔드포인트(예: 실거래가)용 data.go.kr Decoding(raw) 키.
# 개별공시지가에는 위 V-World 키가 우선 사용된다.
ASSET_PLAY_DATA_GO_KR_KEY=

# --- Tunable assumptions (see SPEC §8 open questions) ---
# Corporate tax rate used for after-tax net-surplus correction (single-rate model).
ASSET_PLAY_CORPORATE_TAX_RATE=0.22
# 공시지가 -> 시가 보정계수 (national single factor; override per-region in config).
ASSET_PLAY_LAND_PRICE_CORRECTION_FACTOR=1.4
# Screening universe: KOSPI | KOSDAQ | KONEX | ALL  (configurable, KOSPI-first default)
ASSET_PLAY_UNIVERSE=KOSPI

# Local cache directory
ASSET_PLAY_CACHE_DIR=.cache

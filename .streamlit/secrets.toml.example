# Streamlit secrets — 배포 시 '내 키'를 서버측에 심어 방문자가 키 입력 없이 쓰게 한다.
#
# 로컬 배포:   이 파일을 같은 폴더의 secrets.toml 로 복사하고 값을 채운다(git에 안 올라감).
# Streamlit Community Cloud:  앱 → Settings → Secrets 에 아래 내용을 그대로 붙여넣는다.
#
# 키 이름은 .env 와 동일한 ASSET_PLAY_* 플랫 키. 우선순위: 실제 환경변수 > secrets > .env.

ASSET_PLAY_DART_API_KEY = ""     # KR 공시·재무 (한국 쓰려면 필수)
ASSET_PLAY_EDINET_KEY   = ""     # JP 有報 XBRL (일본 쓰려면)
ASSET_PLAY_JQUANTS_KEY  = ""     # JP 주가
ASSET_PLAY_VWORLD_KEY   = ""     # KR 공시지가·면적 (토지 정밀, 선택)
ASSET_PLAY_JUSO_KEY     = ""     # KR 도로명주소 (선택)

# 호스트(공유) 모드: 방문자에게 키/파일 입력 UI를 숨기고 owner 키로만 제공.
ASSET_PLAY_HOSTED = "1"

# (선택) JP 公示地価 GeoJSON 서버 경로 — 영업용 토지 含み益 추정용.
# ASSET_PLAY_LANDPRICE_FILES = "/srv/data/L01-25.geojson,/srv/data/L02-25.geojson"
